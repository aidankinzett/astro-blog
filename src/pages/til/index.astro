---
import BaseHead from "../../components/BaseHead.astro";
import { SITE_DESCRIPTION,SITE_TITLE } from "../../consts";

import BaseLayout from "../../components/BaseLayout.astro";
import RssLink from "../../components/RssLink.astro";
import TilPostList from "../../components/TilPostList.astro";
---

<BaseLayout>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} slot="head" />

  <div slot="beneath-header">
    <p class="text-2xl">TIL</p>
    <RssLink />
  </div>

  <section>
    <TilPostList />
  </section>
</BaseLayout>
